<launch>
  <arg name="device_ip" default="192.168.1.201" />
  <arg name="msop_port" default="2368"/>
  <arg name="difop_port" default="2369"/>
  <arg name="use_gps_ts" default="false" />
  <arg name="pcl_type" default="true" />
  <arg name="lidar_type" default="c16"/>
  <arg name="packet_rate" default="840.0"/>


  <node pkg="lslidar_driver" type="lslidar_driver_node" name="lslidar_driver_node" output="screen">
    <!--param name="pcap" value="$(find lslidar_driver)/pcap/123.pcap" /-->
    <param name="packet_rate" value="$(arg packet_rate)"/>
    <param name="device_ip" value="$(arg device_ip)" />
    <param name="msop_port" value="$(arg msop_port)" />
    <param name="difop_port" value="$(arg difop_port)"/>
    <param name="pcl_type" value="$(arg pcl_type)"/>
    <param name="lidar_type" value="$(arg lidar_type)"/>
    <param name="add_multicast" value="false"/>
    <param name="group_ip" value="224.1.1.2"/>
    <param name="use_gps_ts" value="$(arg use_gps_ts)"/>
    <param name="min_range" value="0.30"/>
    <param name="max_range" value="150.0"/>
    <param name="frame_id" value="rslidar"/>
    <param name="distance_unit" value="0.40"/>
    <param name="angle_disable_min" value="0"/>
    <param name="angle_disable_max" value="0"/>
    <param name="horizontal_angle_resolution" value="0.2"/>  <!--10Hz:0.2  20Hz:0.4 5Hz: 0.1  -->
    <param name="scan_num" value="10"/>
    <param name="read_once" value="false"/>
    <param name="publish_scan" value="true"/>
    <param name="pointcloud_topic" value="rslidar_points"/>
    <param name="coordinate_opt" value="false"/>

    <param name="debug" value="false"/>

    <param name="filter_voxel" value="true"/>
    <param name="filter_leaf_size_m" value="0.05"/>

    <param name="filter_box" value="true"/>
    <param name="crop_negative" value="true"/>
    <param name="keep_organized" value="false"/>
    <param name="filter_front_m" value="0.25"/>
    <param name="filter_back_m" value="0.80"/>
    <param name="filter_left_m" value="0.40"/>
    <param name="filter_right_m" value="0.40"/>
    <param name="filter_lower_height_m" value="0.5"/>
    <param name="filter_higher_height_m" value="0.1"/>

    <param name="filter_plane" value="true"/>

    <!-- 不带壳 -->
    <param name="plane_a" value="0.0"/>
    <param name="plane_b" value="0.288232"/>
    <param name="plane_c" value="0.95756"/>
    <param name="plane_d" value="0.0"/>

    <!-- 老版本壳 -->
    <!-- param name="plane_a" value="0.0"/-->
    <!-- param name="plane_b" value="0.232052"/-->
    <!-- param name="plane_c" value="0.961234"/-->
    <!-- param name="plane_d" value="0.0"/-->

    <param name="plane_distance_threshold" value="0.10"/>
    <param name="plane_filter_x_min" value="-0.8"/>
    <param name="plane_filter_x_max" value="0.8"/>
    <param name="plane_filter_y_min" value="0.0"/>
    <param name="plane_filter_y_max" value="1.7"/>
  </node>

  <!-- node pkg="rviz" type="rviz" name="rviz" args="-d $(find lslidar_driver)/rviz/lslidar.rviz"/ -->
 
  <node pkg="tf" type="static_transform_publisher" name="lidar2base_publisher" args="0.16 0 0.45 1.57 0 0 base_link rslidar 10" />

 <!--node pkg="tf" type="static_transform_publisher" name="laser_link_to_world" args="0 0 0 0 0 0 world laser_link 100" /-->
  
</launch>
