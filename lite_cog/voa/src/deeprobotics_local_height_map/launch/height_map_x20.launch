<launch>
    <!-- 相机竖放或平放 vertical or horizontal or vertical_new-->
    <arg name="camera_pose" default="vertical_new" />
    <!-- 是否打开可视化界面Rviz --> 
    <arg name="enable_rviz" default="false" />
    <!-- 是否打开机器人urdf模型 -->
    <arg name="enable_urdf" default="true" />
    <!-- 是否在Rviz中显示足底轨迹 -->
    <arg name="enable_joint_path" default="false" />
    <!-- 是否打开运动传输程序 -->
    <arg name="enable_transformer" default="false" />
    <!-- 是否使用数据集运行（且没有相机tf） -->
    <arg name="enable_camera_optical_tf" default="false" />
    <!-- 是否打开地形图传输程序 -->
    <arg name="enable_gridmap_transformer" default="true" />
    <!-- 是否打开安全停避障 -->
    <arg name="enable_safety" default="false" />
    <!-- 是否计算四边形约束 -->
    <arg name="enable_quadrangels" default="true" />

    <!-- <env name="ROSCONSOLE_CONFIG_FILE" value="$(find deeprobotics_local_height_map)/config/setting.conf"/> -->

    <group if="$(eval arg('camera_pose') == 'horizontal')">
      <!-- 地形图 -->
      <node pkg="deeprobotics_local_height_map" type="deeprobotics_local_height_map" name="deeprobotics_local_height_map" output="screen">
        <rosparam command="load" file="$(find deeprobotics_local_height_map)/config/param_all_camera_h.yaml" />
      </node>
      <!-- 发布静态TF变换 -->
      <node pkg="tf2_ros" type="static_transform_publisher" name="base2frontupcamera" args="0.404, 0.017, -0.025 0 0.349 0 /base_link /camera_front_up_link" />
      <node pkg="tf2_ros" type="static_transform_publisher" name="base2frontdowncamera" args="0.411, 0.017, -0.003 0 1.047 0 /base_link /camera_front_down_link" />
    </group>

    <group if="$(eval arg('camera_pose') == 'vertical')">
      <!-- 地形图 -->
      <node pkg="deeprobotics_local_height_map" type="deeprobotics_local_height_map" name="deeprobotics_local_height_map" >
        <rosparam command="load" file="$(find deeprobotics_local_height_map)/config/param_all_camera_v.yaml" />
      </node>
      <!-- 发布静态TF变换 -->
      <!-- typec 朝下 -->
      <!-- <node pkg="tf2_ros" type="static_transform_publisher" name="base2frontleftcamera" args="0.4233 0.04598 0.02223 0.6532815 0.0308436 -0.2705981 0.7064338 /base_link /camera_front_left_link" />
      <node pkg="tf2_ros" type="static_transform_publisher" name="base2frontrightcamera" args="0.4233 -0.04598 0.02223 0.7064338 0.2705981 -0.0308436 0.6532815 /base_link /camera_front_right_link" /> -->
      <!-- 带灯第一版3d打印 -->
      <node pkg="tf2_ros" type="static_transform_publisher" name="base2frontleftcamera" args="0.4244 0.04574 0.02817 0.6532815 0.0308436 -0.2705981 0.7064338 /base_link /camera_front_left_link" />
      <node pkg="tf2_ros" type="static_transform_publisher" name="base2frontrightcamera" args="0.4244 -0.04574 0.02817 0.7064338 0.2705981 -0.0308436 0.6532815 /base_link /camera_front_right_link" />
      <!-- typec 朝上 -->
      <!-- <node pkg="tf2_ros" type="static_transform_publisher" name="base2frontleftcamera" args="0.4093 0.0457 -0.0095 -0.7064338 0.2705981 0.0308436 0.6532815 /base_link /camera_front_left_link" />
      <node pkg="tf2_ros" type="static_transform_publisher" name="base2frontrightcamera" args="0.4093 -0.0457 -0.0095 -0.6532815 0.0308436 0.2705981 0.7064338 /base_link /camera_front_right_link" /> -->
    </group>

    <group if="$(eval arg('camera_pose') == 'vertical_new')">
      <!-- 地形图 -->
      <node pkg="deeprobotics_local_height_map" type="deeprobotics_local_height_map" name="deeprobotics_local_height_map" output="screen">
        <rosparam command="load" file="$(find deeprobotics_local_height_map)/config/param_all_camera_v.yaml" />
      </node>
      <!-- 发布静态TF变换 -->
      <node pkg="tf2_ros" type="static_transform_publisher" name="base2frontleftcamera" args="0.4249 0.04577 0.01972 0.6532815 0.0308436 -0.2705981 0.7064338 /base_link /camera_front_left_link" />
      <node pkg="tf2_ros" type="static_transform_publisher" name="base2frontrightcamera" args="0.4249 -0.04577 0.01972 0.7064338 0.2705981 -0.0308436 0.6532815 /base_link /camera_front_right_link" />
    </group>

    <group if="$(arg enable_safety)">
      <!-- <node pkg="deeprobotics_local_height_map" name="vel_control_node" type="vel_control_node" output="screen">
        <rosparam command="load" file="$(find deeprobotics_local_height_map)/config/control_x20.yaml" />
      </node> -->
      <node pkg="deeprobotics_local_height_map" name="safety_node" type="safety_node"  output="screen">
        <rosparam command="load" file="$(find deeprobotics_local_height_map)/config/safety.yaml" />
      </node>
    </group>

    <group if="$(arg enable_quadrangels)">
      <node name="plane_seg" pkg="plane_seg_ros" type="plane_seg_ros" output="screen"> </node>
    </group>

    <!-- udp -->
    <group if="$(arg enable_transformer)">
      <include file="$(find message_transformer_cpp)/launch/message_transformer_cpp.launch" />
    </group>
    
    <!-- 地形图传输程序 -->
    <group if="$(arg enable_gridmap_transformer)">
      <!-- <node pkg="deeprobotics_grid_map_transformer_old" type="grid_map_transform_app_old" name="grid_map_transform_app_old" /> -->
      <node pkg="deeprobotics_grid_map_transformer" type="grid_map_transform_app" name="grid_map_transform_app" />
    </group>

    <!-- 静态TF变换 -->
    <!-- 后面相机向下30度 -->
    <node pkg="tf2_ros" type="static_transform_publisher" name="base2backcamera" args="-0.4033 -0.017 -0.01365 -0.258819 0 0.9659258 0  /base_link /camera_back_link" />
    <!-- 左边相机朝下30度 -->
    <!-- <node pkg="tf2_ros" type="static_transform_publisher" name="base2leftcamera" args="-0.083 0.14256 0.10136 -0.1830127 0.1830127 0.6830127 0.6830127  /base_link /camera_left_link" /> -->
    <node pkg="tf2_ros" type="static_transform_publisher" name="base2leftcamera" args="-0.117 0.14256 0.10136 0.6830127 0.6830127 -0.1830127 0.1830127 /base_link /camera_left_link" />
    <!-- 右边相机朝下30度 -->
    <node pkg="tf2_ros" type="static_transform_publisher" name="base2rightcamera" args="-0.117 -0.14256 0.10136 0.1830127 0.1830127 -0.6830127 0.6830127  /base_link /camera_right_link" />
    <!-- lidar -->
    <!-- <node pkg="tf2_ros" type="static_transform_publisher" name="base_link2lidar" args="0.32 0 0.14 0 0 0 base_link rslidar" /> -->
    <node pkg="tf2_ros" type="static_transform_publisher" name="base_link2lidar" args="0.3502 0 0.0621 -0.6830127 0.6830127, 0.1830127, -0.1830127 base_link velodyne" />
    <!-- <node pkg="tf2_ros" type="static_transform_publisher" name="base_link2imu" args="-0.1713 0 -0.05925 0 0 0 base_link imu" /> -->

    <!--发布相机静态TF变换-->
    <group if="$(arg enable_camera_optical_tf)">
      <node pkg="tf2_ros" type="static_transform_publisher" name="leftcamera2opticaldepth" args="0 0 0 -0.5 0.5 -0.5 0.5 /camera_front_left_link /camera_front_left_depth_optical_frame" />
      <node pkg="tf2_ros" type="static_transform_publisher" name="rightcamera2opticaldepth" args="0 0 0 -0.5 0.5 -0.5 0.5 /camera_front_right_link /camera_front_right_depth_optical_frame" />
      <node pkg="tf2_ros" type="static_transform_publisher" name="leftcamera2opticalcolor" args="0 0.015 0 -0.5 0.5 -0.5 0.5 /camera_front_left_link /camera_front_left_color_optical_frame" />
      <node pkg="tf2_ros" type="static_transform_publisher" name="rightcamera2opticalcolor" args="0 0.015 0 -0.5 0.5 -0.5 0.5 /camera_front_right_link /camera_front_right_color_optical_frame" />
      <node pkg="tf2_ros" type="static_transform_publisher" name="upcamera2opticaldepth" args="0 0 0 -0.5 0.5 -0.5 0.5 /camera_front_up_link /camera_front_up_depth_optical_frame" />
      <node pkg="tf2_ros" type="static_transform_publisher" name="downcamera2opticaldepth" args="0 0 0 -0.5 0.5 -0.5 0.5 /camera_front_down_link /camera_front_down_depth_optical_frame" />
      <node pkg="tf2_ros" type="static_transform_publisher" name="upcamera2opticalcolor" args="0 0.015 0 -0.5 0.5 -0.5 0.5 /camera_front_up_link /camera_front_up_color_optical_frame" />
      <node pkg="tf2_ros" type="static_transform_publisher" name="downcamera2opticalcolor" args="0 0.015 0 -0.5 0.5 -0.5 0.5 /camera_front_down_link /camera_front_down_color_optical_frame" />
      <node pkg="tf2_ros" type="static_transform_publisher" name="backcamera2opticaldepth" args="0 0 0 -0.5 0.5 -0.5 0.5 /camera_back_link /camera_back_depth_optical_frame" />
      <node pkg="tf2_ros" type="static_transform_publisher" name="backcamera2opticalcolor" args="0 0.015 0 -0.5 0.5 -0.5 0.5 /camera_back_link /camera_back_color_optical_frame" />
    </group>
    
    <!-- urdf -->
    <group if="$(arg enable_urdf)">
      <node pkg="tf2_ros" type="static_transform_publisher" name="base2urdf" args="0 0 0 0 0 0 /base_link /dummy" />
      <param name="robot_description" textfile="$(find lite3)/Lite3/Lite3.urdf" />
      <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" />
    </group>

    <!-- joint path -->
    <group if="$(arg enable_joint_path)">
      <node name="draw" pkg="deeprobotics_local_height_map" type="draw"  output="screen" />
    </group>

    <!-- RVIZ -->
    <group if="$(arg enable_rviz)">
      <node name="rviz" pkg="rviz" type="rviz" args="-d $(find deeprobotics_local_height_map)/rviz/height_map_camera.rviz" />
    </group>

</launch>


