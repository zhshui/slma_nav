# Gateway
GATEWAY_PORT=8080
JWT_SECRET=go2-nav-robot-2026

# Map output directory (place PGM+YAML files here for navigation to use)
MAP_DIR=/home/unitree/go2_nav/lite_cog/system/map

# ROS mode: "mock" or "rosbridge"
ROS_MODE=rosbridge
ROSBRIDGE_URL=ws://127.0.0.1:9090

# ROS topics (override defaults)
# ROS_TOPIC_MAP=/map
# ROS_TOPIC_TF=/tf
# ROS_TOPIC_LIDAR=/livox/lidar
# ROS_TOPIC_CMD_VEL=/cmd_vel
# ROS_TOPIC_VIRTUAL_OBSTACLES=/virtual_obstacles
# ROS_TOPIC_VIRTUAL_OBSTACLES_TYPE=std_msgs/String
# ROS_TOPIC_MOVE_BASE_GOAL=/move_base/goal
# ROS_TOPIC_MOVE_BASE_SIMPLE_GOAL=/move_base_simple/goal
# ROS_PUBLISH_MOVE_BASE_SIMPLE_GOAL=0

# Motion control
MOTION_START_SCRIPT=/home/unitree/go2_nav/go2_SDK_ws/go2_cmd_vel.sh

# Nav goal rate limiting
# NAV_GOAL_RATE_LIMIT_WINDOW_MS=5000
# NAV_GOAL_RATE_LIMIT_COUNT=20

# Map hooks for custom navigation framework
MAP_SAVE_HOOK=/home/unitree/go2_nav/lite_cog/system/scripts/slam/save_map_hook.sh
MAP_SWITCH_HOOK=/home/unitree/go2_nav/lite_cog/system/scripts/slam/switch_map_hook.sh
MAP_STOP_HOOK=/home/unitree/go2_nav/lite_cog/system/scripts/slam/map_stop_hook.sh

# SLAM (建图) script
SLAM_START_SCRIPT=/home/unitree/go2_nav/SC-FAST-LIO-main/start_slam.sh

# Nav script
NAV_START_SCRIPT=/home/unitree/go2_nav/lite_cog/system/scripts/nav/start_nav.sh

# Task script (multi-point nav)
TASK_START_SCRIPT=/home/unitree/go2_nav/lite_cog/pipeline/src/pipeline_tracking/scripts/Task.py
TASK_DATA_DIR=/home/unitree/go2_nav/lite_cog/pipeline/src/pipeline_tracking/data

# Lidar script
LIDAR_START_SCRIPT=/home/unitree/go2_nav/lite_cog/system/scripts/lidar/start_lidar.sh
